{
  "uid": "nantian-gw-obsv",
  "title": "Nantian Gateway",
  "schemaVersion": 39,
  "tags": [
    "controlplane",
    "dataplane",
    "grafana",
    "observability",
    "nantian-gw",
    "prometheus"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Prometheus",
        "query": {
          "query": "prometheus",
          "refId": "StandardVariableQuery"
        },
        "regex": "",
        "refresh": 1
      },
      {
        "name": "namespace",
        "type": "query",
        "label": "Namespace",
        "query": {
          "query": "label_values(nantian_gateway_dataplane_ready, namespace)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "nantian-gw",
          "value": "nantian-gw"
        },
        "definition": "label_values(nantian_gateway_dataplane_ready, namespace)"
      },
      {
        "name": "pod_dp",
        "type": "query",
        "label": "Dataplane Pod",
        "query": {
          "query": "label_values(nantian_gateway_dataplane_ready{namespace=~\"$namespace\"}, pod)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "definition": "label_values(nantian_gateway_dataplane_ready{namespace=~\"$namespace\"}, pod)"
      },
      {
        "name": "job_controlplane",
        "type": "query",
        "label": "Control Plane Job",
        "query": {
          "query": "label_values(nantian_gateway_controlplane_admin_requests_total, job)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "instance_cp",
        "type": "query",
        "label": "CP Instance",
        "query": {
          "query": "label_values(nantian_gateway_controlplane_admin_requests_total{job=~\"$job_controlplane\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "job_dataplane",
        "type": "query",
        "label": "Data Plane Job",
        "query": {
          "query": "label_values(nantian_gateway_dataplane_admin_requests_total, job)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "instance_dp",
        "type": "query",
        "label": "DP Instance",
        "query": {
          "query": "label_values(nantian_gateway_dataplane_admin_requests_total{job=~\"$job_dataplane\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
