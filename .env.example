# ===== 必需 =====
# NextAuth 密钥，用于加密 session token
# 生成方式: openssl rand -base64 32
AUTH_SECRET=

# ===== 可选（有默认值）=====
# 控制面管理 API 地址
# CONTROLPLANE_ADMIN_URL=http://localhost:18081

# 数据面管理 API 地址
# DATAPLANE_ADMIN_URL=http://localhost:19080

# 数据面管理 API 的 Bearer Token（可选）
# 当数据面 admin 配置了与控制面不同的 token 时设置此项；
# 未设置时复用控制面 session token
# DATAPLANE_BEARER_TOKEN=

# 启用 HSTS（生产环境建议开启）
# DASHBOARD_ENABLE_HSTS=false
